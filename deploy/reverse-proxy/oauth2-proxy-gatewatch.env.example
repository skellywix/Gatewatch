# Copy to /etc/oauth2-proxy/gatewatch.env and chmod 0640.
# OAuth2 Proxy maps these environment variables to command-line flags.

OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_PROVIDER_DISPLAY_NAME="Microsoft Entra ID"
OAUTH2_PROXY_OIDC_ISSUER_URL=https://login.microsoftonline.com/REPLACE_WITH_ENTRA_TENANT_ID/v2.0
OAUTH2_PROXY_CLIENT_ID=REPLACE_WITH_ENTRA_CLIENT_ID
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_WITH_ENTRA_CLIENT_SECRET
OAUTH2_PROXY_REDIRECT_URL=https://gatewatch.example.com/oauth2/callback

# Generate with:
# python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=REPLACE_WITH_32_BYTE_BASE64URL_COOKIE_SECRET
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_HTTPONLY=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax

OAUTH2_PROXY_HTTP_ADDRESS=127.0.0.1:4180
OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_TRUSTED_PROXY_IPS=127.0.0.1/32,::1/128
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_SCOPE="openid profile email"
OAUTH2_PROXY_OIDC_GROUPS_CLAIM=groups
OAUTH2_PROXY_SET_XAUTHREQUEST=true
OAUTH2_PROXY_PASS_BASIC_AUTH=false
OAUTH2_PROXY_PASS_USER_HEADERS=false
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true

# Optional: restrict sign-in to a group emitted in the Entra groups claim.
# OAUTH2_PROXY_ALLOWED_GROUPS=REPLACE_WITH_GROUP_OBJECT_ID_OR_NAME
