# Copy to docker/full-test/.env if you want local overrides.
# These are test-only values for the Docker lab. Do not reuse them in production.

GATEWATCH_FULL_TEST_BIND_ADDRESS=127.0.0.1
GATEWATCH_FULL_TEST_APP_PORT=18107

GATEWATCH_FULL_TEST_PROXY_SECRET=GatewatchFullTestProxySecret123!
GATEWATCH_FULL_TEST_AD_ADMIN_PASSWORD=GatewatchTest123!
GATEWATCH_FULL_TEST_AD_SYNC_PASSWORD=GatewatchSync123!

GATEWATCH_FULL_TEST_ADMIN_GROUP=GATEWATCH\AccessRegister-Admins
GATEWATCH_FULL_TEST_SUPERVISOR_GROUP=GATEWATCH\AccessRegister-Supervisors
GATEWATCH_FULL_TEST_REVIEWER_GROUP=GATEWATCH\AccessRegister-Reviewers
GATEWATCH_FULL_TEST_HR_GROUP=GATEWATCH\AccessRegister-HR
GATEWATCH_FULL_TEST_READONLY_GROUP=GATEWATCH\AccessRegister-ReadOnly
