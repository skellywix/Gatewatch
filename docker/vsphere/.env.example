# Copy this file to docker/vsphere/.env on the vSphere VM.
# Do not commit the real .env file.

GATEWATCH_IMAGE=gatewatch:vsphere
GATEWATCH_CONTAINER_NAME=gatewatch-app
GATEWATCH_DATA_VOLUME=gatewatch-data
GATEWATCH_NETWORK=gatewatch-internal

# Keep this on 127.0.0.1 unless the reverse proxy is on another host and the VM firewall only allows that proxy.
GATEWATCH_BIND_ADDRESS=127.0.0.1
GATEWATCH_APP_PORT=8087

ACCESS_REGISTER_SCHEDULER=1
ACCESS_REGISTER_PROXY_SECRET=replace-with-long-random-proxy-only-value

ACCESS_REGISTER_ADMIN_GROUPS=DOMAIN\AccessRegister-Admins
ACCESS_REGISTER_SUPERVISOR_GROUPS=DOMAIN\AccessRegister-Supervisors
ACCESS_REGISTER_REVIEWER_GROUPS=DOMAIN\AccessRegister-Reviewers
ACCESS_REGISTER_HR_GROUPS=DOMAIN\AccessRegister-HR
ACCESS_REGISTER_READONLY_GROUPS=DOMAIN\AccessRegister-ReadOnly
